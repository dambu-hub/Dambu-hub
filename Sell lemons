-- 4. Real-Time Intervallic Rebirth Engine
task.spawn(function()
    while true do
        task.wait(0.1)
        if AutoRebirth and TycoonRemotes then
            local remote = TycoonRemotes:FindFirstChild("Rebirth")
            if remote then
                local currentTime = os.clock()
                local timePassed = currentTime - lastRebirthTimestamp
                local timeLeft = math.max(0, math.ceil(RebirthTimeCooldown - timePassed))
                
