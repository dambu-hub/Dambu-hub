end)

-- 9. Server Hopper
local function serverHopper()
    local ApiUrl = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
    local success, result = pcall(function() return HttpService:JSONDecode(game:HttpGet(ApiUrl)) end)
    if success and result and result.data then
        for _, server in ipairs(result.data) do
            if server.playing < server.maxPlayers and server.id ~= game.JobId then
                TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                break
            end
        end
    end
end

-- 10. Sewer Core
local function touchPart(hrp, part)
    pcall(function()
        firetouchinterest(hrp, part, 0)
        firetouchinterest(hrp, part, 1)
    end)
end

local function pullAllLevers()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local sewer = Workspace:FindFirstChild("Map") and Workspace.Map:FindFirstChild("Sewer") or Workspace
    for _, o in ipairs(sewer:GetDescendants()) do
        if o:IsA("BasePart") and (o.Name == "Lever" or o.Name:lower():match("lever") or o.Name == "VineKey" or o.Name == "UFOKey") then
            touchPart(hrp, o)
        end
    end
end

local function doSewerRun()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local sewer = Workspace:FindFirstChild("Map") and Workspace.Map:FindFirstChild("Sewer")
    if not hrp or not sewer then return end

    pullAllLevers()
    task.wait(0.2)

    local cashVine = sewer:FindFirstChild("CashVine")
    if cashVine and cashVine:FindFirstChild("VineDoor") then
        for _, o in ipairs(cashVine.VineDoor:GetDescendants()) do
            if o:IsA("BasePart") then touchPart(hrp, o) end
        end
    end
    task.wait(0.2)

    if cashVine and cashVine:FindFirstChild("CashVine") then
        local vineModel = cashVine.CashVine
        pcall(function() hrp.CFrame = vineModel:GetPivot() + Vector3.new(0, 3, 0) end)
        task.wait(0.2)
        for _, o in ipairs(vineModel:GetDescendants()) do
            if o:IsA("BasePart") then touchPart(hrp, o) end
        end
    end
end

