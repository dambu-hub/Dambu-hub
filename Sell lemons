--// Wait for Tycoon Securely
local userTycoon = nil
local retries = 0

while not userTycoon and retries < 30 do
    for _, v in ipairs(Workspace:GetChildren()) do
        if v:IsA("Folder") and v.Name:match("Tycoon%d") then
            local owner = v:FindFirstChild("Owner")
            if owner and owner.Value == LocalPlayer then
                userTycoon = v
                break
            end
        end
    end
    if not userTycoon then
        retries = retries + 1
        task.wait(1)
    end
end

if not userTycoon then
    print("Dambu Hub: Hindi nahanap ang Tycoon mo. Siguraduhing naka-claim ka na bago i-execute!")
    return
end

