-- 1. Auto Build Tycoon (May kasamang Auto-Wake Layer)
task.spawn(function()
    while true do
        task.wait(0.1)
        if AutoBuy and Purchases then
            -- Pinipilit nitong gisingin ang income stream para magka-pera agad kahit nag-0 pagka-rebirth
            if TycoonRemotes then
                local wake = TycoonRemotes:FindFirstChild("WakeIncomeStream")
                if wake then pcall(function() wake:InvokeServer("LemonStand") end) end
            end

            for _, obj in ipairs(Purchases:GetDescendants()) do
                if obj:IsA("Model") and obj:GetAttribute("Shown") == true and obj:GetAttribute("Purchased") ~= true then
                    local purchase = obj:FindFirstChild("Purchase")
                    if purchase and purchase:IsA("RemoteFunction") then
                        pcall(function() 
                            purchase:InvokeServer() 
                            stats.buys = stats.buys + 1
                        end)
                    end
                end
            end
        end
    end
end)

-- 2. Fast Auto Upgrade Machines (In-inject dito ang hiling mong non-stop Wake Income)
local upgradeRemotes = {}
local lastUpgradeScan = 0

local function refreshUpgradeRemotes()
    table.clear(upgradeRemotes)
    if not Purchases then return end
    for _, obj in ipairs(Purchases:GetDescendants()) do
        if obj:IsA("RemoteFunction") and obj.Name == "Upgrade" then
            table.insert(upgradeRemotes, obj)
        end
    end
end

task.spawn(function()
    while true do
        task.wait(0.15)
        if AutoUpgrade then
            -- Paniguradong Trigger: Kapag naka-on ang Auto Upgrade, laging gigisingin ang LemonStand para iwas hinto
            if TycoonRemotes then
                local wake = TycoonRemotes:FindFirstChild("WakeIncomeStream")
                if wake then pcall(function() wake:InvokeServer("LemonStand") end) end
            end

            if os.time() - lastUpgradeScan > 5 then
                refreshUpgradeRemotes()
                lastUpgradeScan = os.time()
            end

            for _, remote in ipairs(upgradeRemotes) do
                if remote.Parent then
                    pcall(function()
                        for lvl = 1, 100 do
                            local success, res = pcall(function() return remote:InvokeServer(lvl) end)
                            if not success or res == false then break end
                            stats.upgrades = stats.upgrades + 1
                        end
                    end)
                end
            end
        end
    end
end)

