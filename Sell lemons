                    timeDisplayString = string.format("Rebirthing in: %d second(s)", timeLeft)
                else
                    timeDisplayString = "Executing Rebirth..."
                    pcall(function()
                        remote:InvokeServer()
                        stats.rebirths = stats.rebirths + 1
                    end)
                    lastRebirthTimestamp = os.clock()
                    task.wait(1)
                end
            end
        else
            timeDisplayString = "Engine Offline"
        end
    end
end)

